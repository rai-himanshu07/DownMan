# dependencies
node_modules
dist
dist-ssr
*.local

# secrets / local env — never commit AMO signing creds, tokens, API keys, etc.
.env
.env.*
!.env.example

# editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store

# rust / tauri
src-tauri/target
src-tauri/binaries/*
!src-tauri/binaries/.gitkeep
# Tauri-generated capability schemas (regenerated on every build)
src-tauri/gen/schemas

# extension build artefacts (generated by scripts/build_extension.sh)
extensions/DownMan.zip
extensions/DownMan.xpi
extensions/DownMan-signed.xpi
.web-ext-artifacts/

# release binaries (staged for GitHub Releases; notes + checksums stay tracked)
release/**/*.deb
release/**/*.xpi
release/**/*.zip

# yt-dlp sidecar copy (generated from binaries/yt-dlp by scripts/prepare_binaries.sh)
src-tauri/binaries/downman-ytdlp-x86_64-unknown-linux-gnu

# logs
*.log
npm-debug.log*

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json
