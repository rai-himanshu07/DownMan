{
  "manifest_version": 3,
  "name": "DownMan Connector",
  "version": "1.2.0",
  "key": "",
  "description": "Send downloads to DownMan with one-click per-media controls.",
  "permissions": ["downloads", "downloads.shelf", "downloads.ui", "contextMenus", "storage", "webRequest", "tabs", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DownMan",
    "default_icon": { "16": "icon16.png", "32": "icon32.png" }
  },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["mse-probe.js"], "run_at": "document_start", "all_frames": true, "world": "MAIN" },
    { "matches": ["<all_urls>"], "js": ["media-resolver.js", "content.js"], "run_at": "document_idle", "all_frames": true }
  ],
  "icons": { "16": "icon16.png", "32": "icon32.png", "48": "icon48.png", "128": "icon128.png" },
  "browser_specific_settings": {
    "gecko": {
      "id": "downman@local",
      "strict_min_version": "140.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  }
}
